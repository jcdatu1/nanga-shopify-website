{%- comment -%}
  Icon features grid — NANGA.
  Responsive grid of centered feature columns: an icon in a light-gray square
  tile (theme icon set, optional image override), a title, and short text.
  No JS; styles scoped to .cif in assets/c-icon-features.css.
{%- endcomment -%}
<link rel="stylesheet" href="{{ 'c-icon-features.css' | asset_url }}" {%- render 'lazy-stylesheet-attrs' %}>

<div class="section-id-{{ section.id }} cif{% if section.settings.color_scheme != 'default' %} use-color-scheme use-color-scheme--{{ section.settings.color_scheme }} fully-padded-row--medium{% endif %}">
  <div class="container{% if section.settings.full_width %} container--no-max{% endif %}">
    <div class="cif__grid" style="--cif-cols: {{ section.settings.columns_desktop }}; --cif-cols-mobile: {{ section.settings.columns_mobile }};">
      {%- for block in section.blocks -%}
        <div class="cif__feature" {{ block.shopify_attributes }} {%- render 'animation-attrs', attrs: 'data-cc-animate' -%}>
          {%- if block.settings.image != blank -%}
            <span class="cif__tile">
              <img
                src="{{ block.settings.image | image_url: width: 64 }}"
                srcset="{{ block.settings.image | image_url: width: 64 }} 64w, {{ block.settings.image | image_url: width: 128 }} 128w"
                sizes="32px"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
                alt="{{ block.settings.image.alt | escape }}">
            </span>
          {%- elsif block.settings.icon != 'none' -%}
            <span class="cif__tile">{% render 'icon', icon: block.settings.icon %}</span>
          {%- endif -%}

          {%- if block.settings.title != blank -%}
            <h3 class="cif__title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <div class="cif__text rte">{{ block.settings.text }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "C Icon features",
  "class": "section-c-icon-features",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["aside"]
  },
  "settings": [
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full page width",
      "default": false
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "star",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "accessible", "label": "Accessible" },
            { "value": "award", "label": "Award" },
            { "value": "beach", "label": "Beach" },
            { "value": "box", "label": "Box" },
