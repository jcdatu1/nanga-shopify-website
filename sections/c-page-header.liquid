{%- comment -%}
  Page header — NANGA.
  Flat page-title band: H1 title + reading-width subtitle, left-aligned in the
  page-width container, with a per-section background color and optional bottom
  border. Covers the design's Knowledge/Journal/category header variants from
  settings alone. No JS; styles scoped to .cph in assets/c-page-header.css.

  Contextual fallback: a blank title uses collection.title (collection
  templates) or page.title (page templates); a blank subtitle on a collection
  uses collection.description. Non-blank settings always win.
{%- endcomment -%}
<link rel="stylesheet" href="{{ 'c-page-header.css' | asset_url }}" {%- render 'lazy-stylesheet-attrs' %}>

<div
  class="section-id-{{ section.id }} cph{% if section.settings.show_border %} cph--bordered{% endif %}"
  style="--cph-bg: {{ section.settings.background_color }}; --cph-pad-top-mobile: {{ section.settings.padding_top_mobile }}px; --cph-pad-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px; --cph-pad-top-desktop: {{ section.settings.padding_top_desktop }}px; --cph-pad-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;"
  {%- render 'animation-attrs', attrs: 'data-cc-animate' -%}>
  <div class="container">
    {%- liquid
      assign header_title = section.settings.title
      if header_title == blank
        if collection
          assign header_title = collection.title
        elsif page
          assign header_title = page.title
        endif
      endif

      assign header_subtitle = section.settings.subtitle
      if header_subtitle == blank and collection
        assign header_subtitle = collection.description
      endif
    -%}

    {%- if header_title != blank -%}
      {%- if section.settings.use_h1 -%}
        <h1 class="cph__title">{{ header_title | escape }}</h1>
      {%- else -%}
        <h2 class="cph__title">{{ header_title | escape }}</h2>
      {%- endif -%}
    {%- endif -%}

    {%- if header_subtitle != blank -%}
      <div class="cph__subtitle rte">{{ header_subtitle }}</div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "C Page header",
  "class": "section-c-page-header",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["aside"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Page title"
    },
    {
      "type": "checkbox",
      "id": "use_h1",
      "label": "Set as primary page heading",
      "info": "Use <h1> tag. One per page recommended.",
      "default": true
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f9fafb"
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show bottom border",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Top padding (desktop)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Bottom padding (desktop)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "C Page header",
      "category": "Info"
    }
  ]
}
{% endschema %}
