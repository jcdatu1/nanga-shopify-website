{%- comment -%}
  Collection product grid — NANGA.
  Title-less collection section: faceted filters + a responsive grid of the lean
  'product-card' snippet. Reuses the theme's native <filter-container> AJAX engine
  (assets/main.js) for dynamic filter / sort / pagination — no new JS. Desktop is a
  left filter sidebar + product column (count + sort) per the Figma; mobile uses the
  theme's native filter drawer with a Filter / Sort button row.

  The collection title lives in a separate section — none is rendered here.
{%- endcomment -%}
<link rel="stylesheet" href="{{ 'c-main-collection.css' | asset_url }}" {%- render 'lazy-stylesheet-attrs' %}>

{% paginate collection.products by section.settings.coll_num_per_page_int %}
{%- liquid
  assign current_sort = collection.sort_by | default: collection.default_sort_by

  assign show_filters = section.settings.enable_filtering
  if collection.filters == empty
    assign show_filters = false
  endif

  if section.settings.tag_style == 'dark'
    assign badge_bg = '#000000'
    assign badge_text = '#ffffff'
  else
    assign badge_bg = '#ffffff'
    assign badge_text = '#000000'
  endif
-%}

<div class="cmc section-id-{{ section.id }}" data-section-id="{{ section.id }}" {%- render 'animation-attrs', attrs: 'data-cc-animate' -%}>
  <div class="container{% if settings.use_fullwidth_layout %} container--no-max{% endif %}">
    <filter-container
      class="cmc__container filter-container filter-container--side filter-container--show-filters-desktop"
      data-ajax-filtering="{{ settings.ajax_products }}"
      data-filter-section-id="{{ section.id }}"
      data-ajax-scroll-to>
      {% if show_filters or section.settings.show_sort %}
        {% render 'cmc-filters', filter_context: collection, clear_url: collection.url, current_sort: current_sort %}
      {% endif %}

      <div class="filters-adjacent collection-listing" data-ajax-container>
        {%- comment -%} Mobile filter / sort buttons — both open the theme's native drawer {%- endcomment -%}
        {% if show_filters or section.settings.show_sort %}
          <div class="cmc__mobile-bar">
            {% if show_filters %}
              <button type="button" class="cmc__bar-btn" data-toggle-filters>
                <span class="cmc__bar-btn-icon">{% render 'icon-filter' %}</span>
                <span>{{ 'products.filtering.filter' | t }}</span>
              </button>
            {% endif %}
            {% if section.settings.show_sort %}
              <button type="button" class="cmc__bar-btn" data-toggle-filters>
                <span>{{ 'products.sorting.sort_by_label' | t }}</span>
                <span class="cmc__bar-btn-icon">{% render 'icon-chevron-down', stroke_width: 1.3 %}</span>
              </button>
            {% endif %}
          </div>
        {% endif %}

        {%- comment -%} Desktop toolbar: product count (left) + sort dropdown (right) {%- endcomment -%}
        {% if section.settings.show_total or section.settings.show_sort %}
          <div class="cmc__toolbar">
            {% if section.settings.show_total and paginate.items > 0 %}
              <p class="cmc__count">{{ 'sections.collection.product_count' | t: count: paginate.items }}</p>
            {% endif %}

            {% if section.settings.show_sort %}
              <span class="cmc__sort">
                <link-dropdown class="link-dropdown link-dropdown--right-aligned">
                  <div class="visually-hidden" id="sort-dropdown-heading">{{ 'products.sorting.sort_by_label' | t | escape }}</div>
                  <button class="link-dropdown__button has-motion" aria-expanded="false" aria-controls="sort-dropdown-options" aria-describedby="sort-dropdown-heading">
                    <span class="link-dropdown__button-text">
                      {%- for option in collection.sort_options -%}
                        {%- if current_sort == option.value -%}
                          {{ option.name | escape }}
                          {%- break -%}
                        {%- endif -%}
                      {%- endfor -%}
                    </span>
                    <span class="link-dropdown__button-icon has-motion">{% render 'icon-chevron-down', stroke_width: 1.3 %}</span>
                  </button>
                  <div class="link-dropdown__options" id="sort-dropdown-options">
                    <div class="link-dropdown__options-inner">
                      {%- for option in collection.sort_options -%}
                        {%- liquid
                          if section.settings.sort_show_featured == false and option.value == 'manual' and collection.default_sort_by != 'manual'
                            continue
                          endif
                          if section.settings.sort_show_best == false and option.value == 'best-selling' and collection.default_sort_by != 'best-selling'
                            continue
                          endif
                          if section.settings.sort_show_alpha == false and option.value == 'title-ascending' and collection.default_sort_by != 'title-ascending'
                            continue
                          endif
                          if section.settings.sort_show_alpha == false and option.value == 'title-descending' and collection.default_sort_by != 'title-descending'
                            continue
                          endif
                          if section.settings.sort_show_price == false and option.value == 'price-ascending' and collection.default_sort_by != 'price-ascending'
                            continue
                          endif
                          if section.settings.sort_show_price == false and option.value == 'price-descending' and collection.default_sort_by != 'price-descending'
                            continue
                          endif
                          if section.settings.sort_show_date == false and option.value == 'created-ascending' and collection.default_sort_by != 'created-ascending'
                            continue
                          endif
                          if section.settings.sort_show_date == false and option.value == 'created-descending' and collection.default_sort_by != 'created-descending'
                            continue
                          endif
                        -%}
                        <a href="{{ request.path | sort_by: option.value | escape }}" class="link-dropdown__link{% if current_sort == option.value %} link-dropdown__link--active{% endif %}">{{ option.name | escape }}</a>
                      {%- endfor -%}
                    </div>
                  </div>
                </link-dropdown>
              </span>
            {% endif %}
          </div>
        {% endif %}

        {% if collection.products.size == 0 %}
          <h5 class="cmc__empty align-centre">{{ 'sections.collection.empty' | t }}</h5>
        {% else %}
          <div class="product-grid cmc__grid product-grid--per-row-{{ section.settings.grid }} product-grid--per-row-mob-{{ section.settings.mobile_grid }}">
            {%- for product in collection.products -%}
              {%- render 'product-card', product: product, badge_position: section.settings.tag_position, show_border: section.settings.show_border, badge_bg: badge_bg, badge_text: badge_text, image_fit: section.settings.image_style, show_type: section.settings.show_type, show_value_props: section.settings.show_value_props, hover_effect: section.settings.hover_effect -%}
            {%- endfor -%}
          </div>
        {% endif %}

        {%- comment -%} Inside [data-ajax-container] so it refreshes with the grid — do not nest another container here. {%- endcomment -%}
        <div class="cmc__pagination">{% render 'pagination-control', paginate: paginate %}</div>
      </div>
    </filter-container>
  </div>
</div>
{% endpaginate %}

{% schema %}
{
  "name": "C Collection grid",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "grid",
      "label": "Products per row (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "mobile_grid",
      "label": "Products per row (mobile)",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "range",
      "id": "coll_num_per_page_int",
      "label": "Products per page",
      "min": 8,
      "max": 50,
      "step": 1,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_total",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "header",
      "content": "Filters"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Show filters",
      "info": "Customize filters with the [Search & Discovery app](https://help.shopify.com/manual/online-store/search-and-discovery/filters)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_filter",
      "label": "Sticky filter sidebar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_filter_counts",
      "label": "Show filter counts",
      "default": false
    },
    {
      "type": "text",
      "id": "price_brackets",
      "label": "Price filter brackets",
      "info": "Comma-separated thresholds (in your store currency) that build the radio price ranges, e.g. 500,700,1000 → Under $500 / $500–$700 / $700–$1000 / Over $1000. Requires the Price filter to be enabled in Search & Discovery.",
      "default": "500,700,1000"
    },
    {
      "type": "header",
      "content": "Sorting"
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sorting",
      "default": true
    },
    {
      "visible_if": "{{ section.settings.show_sort }}",
      "type": "checkbox",
      "id": "sort_show_featured",
      "label": "Enable order: Featured",
      "default": false
    },
    {
      "visible_if": "{{ section.settings.show_sort }}",
      "type": "checkbox",
      "id": "sort_show_best",
      "label": "Enable order: Best selling",
      "default": true
    },
    {
      "visible_if": "{{ section.settings.show_sort }}",
      "type": "checkbox",
      "id": "sort_show_alpha",
      "label": "Enable order: Alphabetical",
      "default": true
    },
    {
      "visible_if": "{{ section.settings.show_sort }}",
      "type": "checkbox",
      "id": "sort_show_price",
      "label": "Enable order: Price",
      "default": true
    },
    {
      "visible_if": "{{ section.settings.show_sort }}",
      "type": "checkbox",
      "id": "sort_show_date",
      "label": "Enable order: Date added",
      "default": true
    },
    {
      "visible_if": "{{ section.settings.show_sort }}",
      "type": "paragraph",
      "content": "The collection's default sort order will always show."
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "select",
      "id": "image_style",
      "label": "Image style",
      "info": "Product shots sit contained on a white padded frame; lifestyle shots fill the frame on a gray tint.",
      "default": "cover",
      "options": [
        { "value": "contain", "label": "Product (contained, white)" },
        { "value": "cover", "label": "Lifestyle (cover, gray)" }
      ]
    },
    {
      "type": "select",
      "id": "hover_effect",
      "label": "Hover effect",
      "info": "'Change to lifestyle image' uses the product's custom.c_lifestyle_photo metafield; products without it keep the zoom.",
      "default": "zoom",
      "options": [
        { "value": "zoom", "label": "Zoom" },
        { "value": "image", "label": "Change to lifestyle image" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_type",
      "label": "Show category line",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_value_props",
      "label": "Show spec line",
      "default": true
    },
    {
      "type": "select",
      "id": "tag_style",
      "label": "Tag style",
      "info": "Controls the product badge colors.",
      "default": "dark",
      "options": [
        { "value": "dark", "label": "Dark (black background)" },
        { "value": "light", "label": "Light (white background)" }
      ]
    },
    {
      "type": "select",
      "id": "tag_position",
      "label": "Tag position",
      "info": "Where the product badge sits on the image.",
      "default": "overlay",
      "options": [
        { "value": "overlay", "label": "Over image" },
        { "value": "inside", "label": "On top of image" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show card border",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "C Collection grid"
    }
  ]
}
{% endschema %}
